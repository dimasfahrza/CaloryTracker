# Supabase — get these from https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Optional — server-side admin tasks (do NOT expose to client)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Gemini (chatbot) — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=...
